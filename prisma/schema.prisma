  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById String?   @map("created_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  company    Company?             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  modules    CurriculumModule[]
  enrolments CurriculumEnrolment[]

  @@unique([companyId, code])
  @@index([isActive])
  @@index([deletedAt])
  @@map("curricula")
}

model CurriculumModule {
  id           String    @id @default(uuid()) @db.Uuid
  curriculumId String    @map("curriculum_id") @db.Uuid
  code         String
  title        String
  description  String?
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById  String?   @map("created_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  curriculum Curriculum             @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  lessons    CurriculumLesson[]
  exams      CurriculumModuleExam[]

  @@unique([curriculumId, code])
  @@index([curriculumId, sortOrder])
  @@index([deletedAt])
  @@map("curriculum_modules")
}

model CurriculumLesson {
  id                 String    @id @default(uuid()) @db.Uuid
  moduleId           String    @map("module_id") @db.Uuid
  contentKey         String    @map("content_key")
  title              String
  description        String?
  sortOrder          Int       @default(0) @map("sort_order")
  estimatedMinutes   Int?      @map("estimated_minutes")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById        String?   @map("created_by") @db.Uuid
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)

  module       CurriculumModule              @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  competencies CurriculumLessonCompetency[]
  progress     LessonProgress[]

  @@unique([moduleId, contentKey])
  @@index([moduleId, sortOrder])
  @@index([contentKey])
  @@index([deletedAt])
  @@map("curriculum_lessons")
}

model CurriculumLessonCompetency {
  id           String    @id @default(uuid()) @db.Uuid
  lessonId     String    @map("lesson_id") @db.Uuid
  competencyId String    @map("competency_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById  String?   @map("created_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  lesson     CurriculumLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  competency Competency       @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@unique([lessonId, competencyId])
  @@index([competencyId])
  @@index([deletedAt])
  @@map("curriculum_lesson_competencies")
}

model CurriculumModuleExam {
  id        String    @id @default(uuid()) @db.Uuid
  moduleId  String    @map("module_id") @db.Uuid
  examId    String    @map("exam_id") @db.Uuid
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById String? @map("created_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  module CurriculumModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  exam   WrittenExam      @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([moduleId, examId])
  @@index([examId])
  @@index([deletedAt])
  @@map("curriculum_module_exams")
}

model CurriculumEnrolment {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  curriculumId String    @map("curriculum_id") @db.Uuid
  employeeId   String    @map("employee_id") @db.Uuid
  enrolledAt   DateTime  @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  completedAt  DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById  String?   @map("created_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  curriculum Curriculum       @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  progress   LessonProgress[]

  @@unique([curriculumId, employeeId])
  @@index([companyId, employeeId])
  @@index([deletedAt])
  @@map("curriculum_enrolments")
}

model LessonProgress {
  id          String               @id @default(uuid()) @db.Uuid
  enrolmentId String               @map("enrolment_id") @db.Uuid
  lessonId    String               @map("lesson_id") @db.Uuid
  status      LessonProgressStatus @default(NOT_STARTED)
  startedAt   DateTime?            @map("started_at") @db.Timestamptz(6)
  completedAt DateTime?            @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById String?              @map("created_by") @db.Uuid
  deletedAt   DateTime?            @map("deleted_at") @db.Timestamptz(6)

  enrolment CurriculumEnrolment @relation(fields: [enrolmentId], references: [id], onDelete: Cascade)
  lesson   CurriculumLesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrolmentId, lessonId])
  @@index([lessonId, status])
  @@index([deletedAt])
  @@map("lesson_progress")
}
