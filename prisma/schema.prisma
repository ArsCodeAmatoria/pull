generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  INSTRUCTOR
  SUPERVISOR
  ASSESSOR
  APPRENTICE
  STUDENT
  OPERATOR
  READ_ONLY
}

enum AppAccess {
  PULL
  PROVEN
  BOTH
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum CompetencyStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CompetencyDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum AssessmentType {
  PRACTICAL
  WRITTEN
  OBSERVATION
  PORTFOLIO
  ORAL
  CONTINUOUS
}

enum AssessmentStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AssessmentOutcome {
  NOT_STARTED
  IN_PROGRESS
  COMPETENT
  NOT_YET_COMPETENT
  REQUIRES_REVIEW
}

enum AssessmentRating {
  PASS
  NEEDS_IMPROVEMENT
  COMPETENT
  EXCEEDS_STANDARD
  NOT_OBSERVED
}

enum AssessmentSignerRole {
  INSTRUCTOR
  APPRENTICE
  WITNESS
}

enum ObservationRating {
  EXCEEDS
  MEETS
  DEVELOPING
  DOES_NOT_MEET
}

enum ObservationType {
  POSITIVE_OBSERVATION
  COACHING_OPPORTUNITY
  COMPETENT_DEMONSTRATION
  UNSAFE_ACT
  UNSAFE_CONDITION
  NEAR_MISS
  FOLLOW_UP_REQUIRED
}

enum ObservationFollowUpStatus {
  NONE
  OPEN
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ExamResultStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  VOIDED
}

enum CertificateStatus {
  PENDING
  ACTIVE
  EXPIRED
  REVOKED
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  RETIRED
  LOST
}

enum EquipmentQualificationStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  REVOKED
}

enum MediaEntityType {
  COMPANY
  EMPLOYEE
  PROJECT
  COMPETENCY
  ASSESSMENT
  ASSESSMENT_RESULT
  OBSERVATION
  EXAM
  EXAM_RESULT
  CERTIFICATE
  EQUIPMENT
  TRAINING_MATRIX
  OTHER
}

enum TrainingRequirementLevel {
  REQUIRED
  RECOMMENDED
  OPTIONAL
}

enum TrainingMatrixCellStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPETENT
  VERIFIED
  NEEDS_REASSESSMENT
  EXPIRED
  EXEMPT
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ALERT
  ASSESSMENT
  EXAM
  CERTIFICATE
  SYSTEM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  ASSIGN
  COMPLETE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum HourEntryType {
  REGULAR
  OVERTIME
  TRAINING
  TRAVEL
  OTHER
}

enum LiftType {
  NONE
  MOBILE_CRANE
  TOWER_CRANE
  OVERHEAD_CRANE
  BOOM_TRUCK
  FORKLIFT
  AERIAL_LIFT
  OTHER
}

enum ExperienceMilestoneKind {
  APPRENTICESHIP
  EQUIPMENT
  PROJECT
  CATEGORY
  GENERAL
}

// =============================================================================
// Identity & tenancy
// =============================================================================

/// Tenant / employer organization.
model Company {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  logoUrl     String?   @map("logo_url")
  website     String?
  phone       String?
  address     String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById String?   @map("created_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  employees              Employee[]
  projects               Project[]
  competencyCategories   CompetencyCategory[]
  competencies           Competency[]
  assessments            Assessment[]
  observations           Observation[]
  writtenExams           WrittenExam[]
  certificates           Certificate[]
  employeeHours          EmployeeHour[]
  equipmentTypes         EquipmentType[]
  equipment              Equipment[]
  equipmentQualifications EquipmentQualification[]
  experienceLogEntries   ExperienceLogEntry[]
  experienceMilestones   ExperienceMilestone[]
  photos                 Photo[]
  videos                 Video[]
  documents              Document[]
  trainingMatrices       TrainingMatrix[]
  notifications          Notification[]
  auditLogs              AuditLog[]
  invites                CompanyInvite[]
  curricula              Curriculum[]
  curriculumEnrolments   CurriculumEnrolment[]

  @@index([deletedAt])
  @@index([isActive])
  @@index([createdById])
  @@map("companies")
}

/// Auth-linked identity (1:1 with Supabase auth.users).
model User {
  id          String    @id @default(uuid()) @db.Uuid
  authUserId  String    @unique @map("auth_user_id")
  email       String
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  avatarUrl   String?   @map("avatar_url")
  phone       String?
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById String?   @map("created_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  settings   UserSettings?
  employees  Employee[]
  invitesSent CompanyInvite[] @relation("InviteSender")

  @@index([email])
  @@index([deletedAt])
  @@index([createdById])
  @@map("users")
}

/// Company employment record. Users belong to companies as employees.
model Employee {
  id                      String         @id @default(uuid()) @db.Uuid
  userId                  String         @map("user_id") @db.Uuid
  companyId               String         @map("company_id") @db.Uuid
  supervisorId            String?        @map("supervisor_id") @db.Uuid
  role                    UserRole       @default(READ_ONLY)
  appAccess               AppAccess      @default(BOTH) @map("app_access")
  status                  EmployeeStatus @default(ACTIVE)
  employeeNumber          String?        @map("employee_number")
  title                   String?
  trade                   String?
  level                   Int            @default(1)
  department              String?
  photoUrl                String?        @map("photo_url")
  hireDate                DateTime?      @map("hire_date") @db.Date
  terminationDate         DateTime?      @map("termination_date") @db.Date
  notes                   String?
  emergencyContactName    String?        @map("emergency_contact_name")
  emergencyContactPhone   String?        @map("emergency_contact_phone")
  emergencyContactRelation String?       @map("emergency_contact_relation")
  createdAt               DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById             String?        @map("created_by") @db.Uuid
  deletedAt               DateTime?      @map("deleted_at") @db.Timestamptz(6)

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supervisor Employee? @relation("EmployeeSupervisor", fields: [supervisorId], references: [id], onDelete: SetNull)
  reports    Employee[] @relation("EmployeeSupervisor")

  projectAssignments     ProjectAssignment[]
  assessmentsAssigned    Assessment[]             @relation("AssessmentAssessor")
  assessmentResults      AssessmentResult[]       @relation("AssessmentSubject")
  assessmentResultsGiven AssessmentResult[]       @relation("AssessmentResultAssessor")
  observationsReceived   Observation[]            @relation("ObservationSubject")
  observationsGiven      Observation[]            @relation("ObservationObserver")
  examResults            ExamResult[]
  certificates           Certificate[]
  employeeHours          EmployeeHour[]
  mediaPhotos            Photo[]                  @relation("PhotoUploader")
  mediaVideos            Video[]                  @relation("VideoUploader")
  mediaDocuments         Document[]               @relation("DocumentUploader")
  trainingMatrixEntries  TrainingMatrixEntry[]
  notifications          Notification[]
  equipmentAssigned      Equipment[]              @relation("EquipmentAssignee")
  assessmentSignatures   AssessmentSignature[]    @relation("AssessmentSigner")
  experienceLogs         ExperienceLogEntry[]     @relation("ExperienceSubject")
  experienceSupervised   ExperienceLogEntry[]     @relation("ExperienceSupervisor")
  equipmentQualifications EquipmentQualification[] @relation("EquipmentQualificationSubject")
  equipmentQualificationsGiven EquipmentQualification[] @relation("EquipmentQualificationAssessor")
  curriculumEnrolments    CurriculumEnrolment[]
  examResultsInstructed   ExamResult[]              @relation("ExamResultInstructor")

  @@unique([companyId, userId])
  @@unique([companyId, employeeNumber])
  @@index([companyId, role])
  @@index([companyId, status])
  @@index([companyId, trade])
  @@index([companyId, appAccess])
  @@index([supervisorId])
  @@index([userId])
  @@index([deletedAt])
  @@index([createdById])
  @@map("employees")
}

model UserSettings {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @unique @map("user_id") @db.Uuid
  emailNotifications  Boolean   @default(true) @map("email_notifications")
  assessmentReminders Boolean   @default(true) @map("assessment_reminders")
  rememberMeDefault   Boolean   @default(true) @map("remember_me_default")
  timezone            String    @default("America/New_York")
  locale              String    @default("en-US")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById         String?   @map("created_by") @db.Uuid
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
  @@map("user_settings")
}

model CompanyInvite {
  id          String       @id @default(uuid()) @db.Uuid
  companyId   String       @map("company_id") @db.Uuid
  email       String
  role        UserRole     @default(OPERATOR)
  token       String       @unique @default(uuid())
  status      InviteStatus @default(PENDING)
  invitedById String       @map("invited_by") @db.Uuid
  expiresAt   DateTime     @map("expires_at") @db.Timestamptz(6)
  acceptedAt  DateTime?    @map("accepted_at") @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById String?      @map("created_by") @db.Uuid
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy User    @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([companyId, email])
  @@index([token])
  @@index([status])
  @@index([deletedAt])
  @@map("company_invites")
}

// =============================================================================
// Projects
// =============================================================================

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  companyId   String        @map("company_id") @db.Uuid
  code        String
  name        String
  description String?
  status      ProjectStatus @default(PLANNED)
  location    String?
  startDate   DateTime?     @map("start_date") @db.Date
  endDate     DateTime?     @map("end_date") @db.Date
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById String?       @map("created_by") @db.Uuid
  deletedAt   DateTime?     @map("deleted_at") @db.Timestamptz(6)

  company            Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignments        ProjectAssignment[]
  assessments        Assessment[]
  observations       Observation[]
  employeeHours      EmployeeHour[]
  equipment          Equipment[]
  trainingMatrices   TrainingMatrix[]
  experienceLogs     ExperienceLogEntry[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([deletedAt])
  @@index([createdById])
  @@map("projects")
}

model ProjectAssignment {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  employeeId  String    @map("employee_id") @db.Uuid
  roleLabel   String?   @map("role_label")
  startsAt    DateTime? @map("starts_at") @db.Date
  endsAt      DateTime? @map("ends_at") @db.Date
  isPrimary   Boolean   @default(false) @map("is_primary")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById String?   @map("created_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([projectId, employeeId])
  @@index([employeeId])
  @@index([deletedAt])
  @@map("project_assignments")
}

// =============================================================================
// Competencies
// =============================================================================

model CompetencyCategory {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  parentId    String?   @map("parent_id") @db.Uuid
  code        String
  name        String
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById String?   @map("created_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent       CompetencyCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     CompetencyCategory[] @relation("CategoryTree")
  competencies Competency[]
  observations Observation[]
  experienceLogs ExperienceLogEntry[]
  experienceMilestones ExperienceMilestone[]

  @@unique([companyId, code])
  @@index([companyId, parentId])
  @@index([deletedAt])
  @@map("competency_categories")
}

model Competency {
  id                      String               @id @default(uuid()) @db.Uuid
  companyId               String               @map("company_id") @db.Uuid
  categoryId              String?              @map("category_id") @db.Uuid
  code                    String
  title                   String
  description             String
  reference               String?
  csaReference            String?              @map("csa_reference")
  asmeReference           String?              @map("asme_reference")
  workSafeBcReference     String?              @map("worksafe_bc_reference")
  requiredDemonstrations  String?              @map("required_demonstrations")
  requiredDemonstrationCount Int?              @map("required_demonstration_count")
  requiredScore           Int?                 @map("required_score")
  difficulty              CompetencyDifficulty @default(INTERMEDIATE)
  estimatedTimeMinutes    Int?                 @map("estimated_time_minutes")
  trade                   String?
  level                   Int                  @default(1)
  status                  CompetencyStatus     @default(DRAFT)
  version                 Int                  @default(1)
  createdAt               DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById             String?              @map("created_by") @db.Uuid
  deletedAt               DateTime?            @map("deleted_at") @db.Timestamptz(6)

  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category              CompetencyCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  criteria              CompetencyCriterion[]
  assessments           Assessment[]
  observations          Observation[]
  examLinks             ExamCompetency[]
  certificates          Certificate[]
  trainingMatrixEntries TrainingMatrixEntry[]
  experienceLogs        ExperienceLogEntry[]
  experienceMilestones  ExperienceMilestone[]
  curriculumLessons     CurriculumLessonCompetency[]

  @@unique([companyId, code, version])
  @@index([companyId, status])
  @@index([companyId, difficulty])
  @@index([categoryId])
  @@index([trade])
  @@index([deletedAt])
  @@map("competencies")
}

model CompetencyCriterion {
  id           String    @id @default(uuid()) @db.Uuid
  competencyId String    @map("competency_id") @db.Uuid
  description  String
  sortOrder    Int       @default(0) @map("sort_order")
  isCritical   Boolean   @default(false) @map("is_critical")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById  String?   @map("created_by") @db.Uuid
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  competency Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@index([competencyId])
  @@index([deletedAt])
  @@map("competency_criteria")
}

// =============================================================================
// Assessments & results
// =============================================================================

model Assessment {
  id           String           @id @default(uuid()) @db.Uuid
  companyId    String           @map("company_id") @db.Uuid
  projectId    String?          @map("project_id") @db.Uuid
  competencyId String?          @map("competency_id") @db.Uuid
  assessorId   String?          @map("assessor_id") @db.Uuid
  type         AssessmentType
  title        String
  description  String?
  status       AssessmentStatus @default(DRAFT)
  scheduledAt  DateTime?        @map("scheduled_at") @db.Timestamptz(6)
  completedAt  DateTime?        @map("completed_at") @db.Timestamptz(6)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById  String?          @map("created_by") @db.Uuid
  deletedAt    DateTime?        @map("deleted_at") @db.Timestamptz(6)

  company    Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project    Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  competency Competency?        @relation(fields: [competencyId], references: [id], onDelete: SetNull)
  assessor   Employee?          @relation("AssessmentAssessor", fields: [assessorId], references: [id], onDelete: SetNull)
  results    AssessmentResult[]
  equipmentQualificationLinks EquipmentQualificationAssessment[]

  @@index([companyId, status])
  @@index([projectId])
  @@index([competencyId])
  @@index([assessorId])
  @@index([deletedAt])
  @@map("assessments")
}

model AssessmentResult {
  id                 String             @id @default(uuid()) @db.Uuid
  assessmentId       String             @map("assessment_id") @db.Uuid
  employeeId         String             @map("employee_id") @db.Uuid
  assessorId         String?            @map("assessor_id") @db.Uuid
  outcome            AssessmentOutcome  @default(NOT_STARTED)
  rating             AssessmentRating?
  score              Int?
  maxScore           Int?               @map("max_score")
  comments           String?
  instructorNotes    String?            @map("instructor_notes")
  apprenticeComments String?            @map("apprentice_comments")
  feedback           String?
  evidenceNotes      String?            @map("evidence_notes")
  assessedAt         DateTime?          @map("assessed_at") @db.Timestamptz(6)
  validUntil         DateTime?          @map("valid_until") @db.Timestamptz(6)
  lockedAt           DateTime?          @map("locked_at") @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById        String?            @map("created_by") @db.Uuid
  deletedAt          DateTime?          @map("deleted_at") @db.Timestamptz(6)

  assessment Assessment            @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  employee   Employee              @relation("AssessmentSubject", fields: [employeeId], references: [id], onDelete: Cascade)
  assessor   Employee?             @relation("AssessmentResultAssessor", fields: [assessorId], references: [id], onDelete: SetNull)
  signatures AssessmentSignature[]

  @@unique([assessmentId, employeeId])
  @@index([employeeId, outcome])
  @@index([employeeId, rating])
  @@index([assessorId])
  @@index([assessedAt])
  @@index([deletedAt])
  @@map("assessment_results")
}

model AssessmentSignature {
  id                 String               @id @default(uuid()) @db.Uuid
  assessmentResultId String               @map("assessment_result_id") @db.Uuid
  signerEmployeeId   String?              @map("signer_employee_id") @db.Uuid
  role               AssessmentSignerRole
  signerName         String               @map("signer_name")
  signedAt           DateTime             @default(now()) @map("signed_at") @db.Timestamptz(6)
  storagePath        String?              @map("storage_path")
  signatureUrl       String?              @map("signature_url")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById        String?              @map("created_by") @db.Uuid
  deletedAt          DateTime?            @map("deleted_at") @db.Timestamptz(6)

  assessmentResult AssessmentResult @relation(fields: [assessmentResultId], references: [id], onDelete: Cascade)
  signerEmployee   Employee?        @relation("AssessmentSigner", fields: [signerEmployeeId], references: [id], onDelete: SetNull)

  @@index([assessmentResultId])
  @@index([signerEmployeeId])
  @@index([deletedAt])
  @@map("assessment_signatures")
}

// =============================================================================
// Observations
// =============================================================================

model Observation {
  id                 String                     @id @default(uuid()) @db.Uuid
  companyId          String                     @map("company_id") @db.Uuid
  projectId          String?                    @map("project_id") @db.Uuid
  categoryId         String?                    @map("category_id") @db.Uuid
  competencyId       String?                    @map("competency_id") @db.Uuid
  employeeId         String                     @map("employee_id") @db.Uuid
  observerId         String                     @map("observer_id") @db.Uuid
  observationType    ObservationType            @map("observation_type")
  context            String
  location           String?
  rating             ObservationRating?
  comments           String?
  notes              String                     @default("")
  correctiveActions  String?                    @map("corrective_actions")
  dueDate            DateTime?                  @map("due_date") @db.Date
  followUpStatus     ObservationFollowUpStatus  @default(NONE) @map("follow_up_status")
  observedAt         DateTime                   @default(now()) @map("observed_at") @db.Timestamptz(6)
  createdAt          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdById        String?                    @map("created_by") @db.Uuid
  deletedAt          DateTime?                  @map("deleted_at") @db.Timestamptz(6)

  company    Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project    Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  category   CompetencyCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  competency Competency?         @relation(fields: [competencyId], references: [id], onDelete: SetNull)
  employee   Employee            @relation("ObservationSubject", fields: [employeeId], references: [id], onDelete: Cascade)
  observer   Employee            @relation("ObservationObserver", fields: [observerId], references: [id], onDelete: Restrict)

  @@index([companyId, observedAt])
  @@index([companyId, observationType])
  @@index([companyId, followUpStatus])
  @@index([employeeId, observedAt])
  @@index([observerId])
  @@index([projectId])
