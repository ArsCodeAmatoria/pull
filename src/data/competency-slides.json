          "headingEmphasis": "yellow",
          "items": [
            {
              "label": "Protect slings from sharp edges and corners on the load",
              "emphasis": "yellow",
              "href": "https://www.worksafebc.com/en/law-policy/occupational-health-safety/searchable-ohs-regulation/ohs-regulation-part-15"
