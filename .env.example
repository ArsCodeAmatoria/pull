# Application
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="pull"

# Database (Supabase Postgres) — shared with Proven, same project.
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?schema=public&sslmode=require&uselibpqcompat=true"
DIRECT_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?schema=public&sslmode=require&uselibpqcompat=true"

# Supabase Auth — same project/keys as Proven so a single login works for both apps.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
